# ============================================
# MCP LeadGen — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Database ---
POSTGRES_PASSWORD=change_me_to_a_strong_password

# --- UI Base URL (used for links in tool responses) ---
UI_BASE=https://gtm-mcp.com

# --- AI Provider Keys (at least one required for lead analysis) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# --- Apollo (company/people search) ---
APOLLO_API_KEY=

# --- SmartLead (email campaigns) ---
SMARTLEAD_API_KEY=

# --- GetSales (outreach automation) ---
GETSALES_API_KEY=
GETSALES_TEAM_ID=

# --- Apify (website scraping proxy) ---
APIFY_PROXY_PASSWORD=

# --- Encryption key for stored API keys ---
# Auto-generated if not set. Set explicitly for persistence across restarts.
ENCRYPTION_KEY=

# --- Telegram Bot (optional — uncomment telegram service in docker-compose.yml) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_NOTIFY_BOT_TOKEN=
